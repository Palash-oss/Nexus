{
  "manifest_version": 3,
  "name": "Nexus Search",
  "version": "1.0.0",
  "description": "Index your browsing history in Nexus for universal search",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://nexus.app/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "run_at": "document_idle",
      "exclude_matches": [
        "*://localhost/*",
        "*://127.0.0.1/*",
        "chrome://*/*",
        "chrome-extension://*/*",
        "*://mail.google.com/*",
        "*://drive.google.com/*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
