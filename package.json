{
  "name": "nexus",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w web",
    "build": "npm run build -w web",
    "lint": "npm run lint -w web",
    "typecheck": "npm run typecheck -w web",
    "db:migrate": "npm run db:migrate -w web",
    "db:generate": "npm run db:generate -w web",
    "db:setup": "node scripts/setup-db.js && npm run db:generate -w web"
  }
}
