generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DocumentSource {
  GMAIL
  DRIVE
  WEB
}

enum IngestionStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

model User {
  id                         String        @id @default(cuid())
  name                       String?
  email                      String?       @unique
  emailVerified              DateTime?
  image                      String?
  googleAccessToken          String?
  googleRefreshToken         String?
  googleAccessTokenExpiresAt DateTime?
  googleScope                String?
  accounts                   Account[]
  sessions                   Session[]
  documents                  Document[]
  ingestionRuns              IngestionRun[]
  extensionTokens            ExtensionToken[]
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Document {
  id                String         @id @default(cuid())
  userId            String
  source            DocumentSource
  sourceDocumentId  String
  title             String
  content           String         @db.Text
  snippet           String?
  author            String?
  url               String
  metadata          Json?
  externalCreatedAt DateTime?
  externalUpdatedAt DateTime?
  embedding         Float[]
  embeddingVector   Float[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, source, sourceDocumentId])
  @@index([userId, source])
  @@index([userId, updatedAt])
}

model IngestionRun {
  id              String          @id @default(cuid())
  userId          String
  source          DocumentSource
  status          IngestionStatus
  startedAt       DateTime        @default(now())
  finishedAt      DateTime?
  totalFetched    Int             @default(0)
  totalIndexed    Int             @default(0)
  totalFailed     Int             @default(0)
  errorSummary    String?
  warnings        Json?
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, source, startedAt])
}

model ExtensionToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @default(cuid())
  createdAt DateTime @default(now())
  lastUsed  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SearchLog {
  id          String   @id @default(cuid())
  userId      String
  query       String
  resultCount Int
  durationMs  Int
  createdAt   DateTime @default(now())
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("landing")
  createdAt DateTime @default(now())
}

model IngestLog {
  id        String         @id @default(cuid())
  userId    String
  source    DocumentSource
  count     Int
  createdAt DateTime       @default(now())
}

